# Environment variables for development
# Copy this file to .env and fill in your values

# Database connection strings
ConnectionStrings__LocalDb=Data Source=(localdb)\\MSSQLLocalDB;Initial Catalog=ShopPv421;Integrated Security=True
ConnectionStrings__RemoteDb=your_remote_db_connection_string_here
ConnectionStrings__AzureBlobs=your_azure_storage_connection_string

# Admin user credentials for seeding
AdminPassword=YourSecureAdminPassword123!

# Email settings (if needed)
# EmailSender__Host=smtp.gmail.com
# EmailSender__Port=587
# EmailSender__Username=your-email@gmail.com
# EmailSender__Password=your-app-password