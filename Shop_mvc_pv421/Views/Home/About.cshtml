@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <!-- Header Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-primary">Discover Shop App</h1>
        <p class="lead text-muted">Delivering quality and excellence since 2026.</p>
        <div class="d-flex justify-content-center">
            <div class="bg-primary" style="height: 4px; width: 100px;"></div>
        </div>
    </div>

    <!-- Image Collection -->
    <div class="row g-4 mb-5">
        <div class="col-md-8">
            <div class="card border-0 shadow-sm h-100">
                <img src="https://placehold.co/800x500/EEE/31343C?text=Our+Flagship+Store" class="card-img-top h-100 object-fit-cover" alt="Main Store">
            </div>
        </div>
        <div class="col-md-4">
            <div class="d-flex flex-column h-100 gap-4">
                <div class="card border-0 shadow-sm flex-fill">
                    <img src="https://placehold.co/400x235/EEE/31343C?text=New+Collection" class="card-img-top h-100 object-fit-cover" alt="Collection">
                </div>
                <div class="card border-0 shadow-sm flex-fill">
                    <img src="https://placehold.co/400x235/EEE/31343C?text=Happy+Customers" class="card-img-top h-100 object-fit-cover" alt="Customers">
                </div>
            </div>
        </div>
    </div>

    <!-- Advantages Section -->
    <div class="row mb-5 text-center">
        <div class="col-12 mb-4">
            <h2 class="fw-bold">Why Choose Us?</h2>
        </div>
        <div class="col-md-4 mb-3">
            <div class="p-4 border rounded-3 shadow-sm bg-white h-100 hover-effect">
                <i class="bi bi-truck fs-1 text-primary mb-3"></i>
                <h4>Fast Delivery</h4>
                <p class="text-muted">We ensure your products arrive safely and on time, every time.</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="p-4 border rounded-3 shadow-sm bg-white h-100 hover-effect">
                <i class="bi bi-shield-check fs-1 text-primary mb-3"></i>
                <h4>Quality Guarantee</h4>
                <p class="text-muted">All our products go through rigorous quality checks before shipping.</p>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="p-4 border rounded-3 shadow-sm bg-white h-100 hover-effect">
                <i class="bi bi-headset fs-1 text-primary mb-3"></i>
                <h4>24/7 Support</h4>
                <p class="text-muted">Our dedicated support team is here to help you around the clock.</p>
            </div>
        </div>
    </div>

    <!-- Team Section -->
    <div class="mb-5">
        <div class="text-center mb-4">
            <h2 class="fw-bold">Meet Our Team</h2>
            <p class="text-muted">The people who make it all happen.</p>
        </div>
        <div class="row g-4">
            <div class="col-sm-6 col-lg-3">
                <div class="card text-center border-0 shadow-sm h-100">
                    <div class="card-body">
                        <img src="https://placehold.co/150x150/png?text=JS" class="rounded-circle mb-3 border border-3 border-white shadow-sm" alt="Employee">
                        <h5 class="card-title fw-bold">Jane Smith</h5>
                        <p class="card-text text-primary">CEO & Founder</p>
                        <p class="small text-muted">Visionary leader with 10+ years of experience in retail.</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card text-center border-0 shadow-sm h-100">
                    <div class="card-body">
                        <img src="https://placehold.co/150x150/png?text=JD" class="rounded-circle mb-3 border border-3 border-white shadow-sm" alt="Employee">
                        <h5 class="card-title fw-bold">John Doe</h5>
                        <p class="card-text text-primary">Head of Marketing</p>
                        <p class="small text-muted">Expert in digital strategies and brand growth.</p>
                    </div>
                </div>
            </div>
            <div class="col-sm-6 col-lg-3">
                <div class="card text-center border-0 shadow-sm h-100">
                    <div class="card-body">
                        <img src="https://placehold.co/150x150/png?text=AB" class="rounded-circle mb-3 border border-3 border-white shadow-sm" alt="Employee">
                        <h5 class="card-title fw-bold">Alice Brown</h5>
                        <p class="card-text text-primary">Lead Designer</p>
                        <p class="small text-muted">Creative mind behind our unique product aesthetics.</p>
                    </div>
                </div>
            </div>
             <div class="col-sm-6 col-lg-3">
                <div class="card text-center border-0 shadow-sm h-100">
                    <div class="card-body">
                        <img src="https://placehold.co/150x150/png?text=MK" class="rounded-circle mb-3 border border-3 border-white shadow-sm" alt="Employee">
                        <h5 class="card-title fw-bold">Mike King</h5>
                        <p class="card-text text-primary">Customer Success</p>
                        <p class="small text-muted">Dedicated to ensuring our customers are always happy.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Contact & Map Section -->
    <div class="row mb-5">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <h2 class="fw-bold mb-4">Visit Us</h2>
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-3 d-flex align-items-center">
                            <i class="bi bi-geo-alt-fill text-primary me-3 fs-4"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Address</h6>
                                <p class="mb-0 text-muted">123 Market Street, Suite 456<br>San Francisco, CA 94103</p>
                            </div>
                        </li>
                        <li class="mb-3 d-flex align-items-center">
                            <i class="bi bi-envelope-fill text-primary me-3 fs-4"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Email</h6>
                                <p class="mb-0 text-muted">hello@shopapp.com</p>
                            </div>
                        </li>
                         <li class="mb-3 d-flex align-items-center">
                            <i class="bi bi-telephone-fill text-primary me-3 fs-4"></i>
                            <div>
                                <h6 class="fw-bold mb-0">Phone</h6>
                                <p class="mb-0 text-muted">+1 (555) 123-4567</p>
                            </div>
                        </li>
                    </ul>
                    <hr>
                    <h6 class="fw-bold">Opening Hours</h6>
                    <p class="text-muted small">
                        Mon - Fri: 9:00 AM - 8:00 PM<br>
                        Sat - Sun: 10:00 AM - 6:00 PM
                    </p>
                </div>
            </div>
        </div>
        <div class="col-lg-6">
            <h2 class="fw-bold mb-4">Find Us on Map</h2>
             <div class="card border-0 shadow-sm overflow-hidden" style="height: 350px;">
                <!-- Placeholder for Google Maps iframe -->
                <iframe 
                    src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d100939.98555098464!2d-122.50764017944336!3d37.75781499660372!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x80859a6d00690021%3A0x4a501367f076adff!2sSan%20Francisco%2C%20CA!5e0!3m2!1sen!2sus!4v1709295655325!5m2!1sen!2sus" 
                    width="100%" 
                    height="100%" 
                    style="border:0;" 
                    allowfullscreen="" 
                    loading="lazy" 
                    referrerpolicy="no-referrer-when-downgrade">
                </iframe>
            </div>
        </div>
    </div>
</div>